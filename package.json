{
  "name": "180-absolute-cinema",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "analyze": "tsc -b && vite build --mode analyze",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:start": "set REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2&& npm --prefix apps/mobile run start -- --port 8090",
    "mobile:android": "set REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2&& npm --prefix apps/mobile run android -- --port 8090",
    "mobile:stack": "npm run mobile:android",
    "mobile:devclient:start": "npm --prefix apps/mobile run start:dev-client -- --port 8081",
    "mobile:devclient:android": "npm --prefix apps/mobile run android:dev",
    "mobile:eas:android:development": "npm --prefix apps/mobile run eas:build:android:development",
    "mobile:env:sync": "node scripts/mobile-env-sync.mjs",
    "mobile:env:doctor": "node scripts/mobile-env-doctor.mjs",
    "mobile:eas:projectid:sync": "node scripts/mobile-eas-projectid-sync.mjs",
    "mobile:ready": "npm run mobile:env:sync && npm run mobile:eas:projectid:sync && npm run mobile:env:doctor && node scripts/mobile-ready.mjs",
    "mobile:phase1:qa": "npm run mobile:ready && npm --prefix apps/mobile exec -- tsc --noEmit && npm run test:mobile:contracts && npm run lint && npm run build",
    "mobile:phase1:smoke:no-push": "npm run mobile:phase1:qa && npm run test:mobile:deeplink:smoke && npm run test:referral:smoke:e2e:fresh",
    "test:referral:smoke:create": "node test-referral-smoke.js create",
    "test:referral:smoke:claim": "node test-referral-smoke.js claim",
    "test:referral:smoke:e2e": "node test-referral-smoke.js e2e",
    "test:referral:smoke:e2e:fresh": "node scripts/referral-smoke-e2e-fresh.mjs",
    "test:mobile:deeplink:smoke": "node scripts/mobile-deeplink-smoke.mjs",
    "test:mobile:contracts": "tsx scripts/mobile-contract-smoke.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.1",
    "@vercel/og": "^0.8.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
