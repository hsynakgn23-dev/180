# Absolute URL to analytics ingest endpoint (required for mobile analytics)
# Remote push token test flow for SDK 53+ requires development build (dev client), not Expo Go.
# Android emulator local dev example:
# EXPO_PUBLIC_ANALYTICS_ENDPOINT=http://10.0.2.2:5173/api/analytics
EXPO_PUBLIC_ANALYTICS_ENDPOINT=

# Optional analytics toggle (default enabled). Set to 0 to disable mobile analytics emit in local dev.
EXPO_PUBLIC_ANALYTICS_ENABLED=1

# Optional explicit daily endpoint (if omitted, derived from analytics endpoint)
# Android emulator local dev example:
# EXPO_PUBLIC_DAILY_API_URL=http://10.0.2.2:5173/api/daily
EXPO_PUBLIC_DAILY_API_URL=

# Required for invite claim API flow (mobile auth token + referral claim)
# Copy from web .env values
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional explicit API base for referral endpoints
# If empty, app derives base from EXPO_PUBLIC_ANALYTICS_ENDPOINT or EXPO_PUBLIC_DAILY_API_URL
# Android emulator local dev example:
# EXPO_PUBLIC_REFERRAL_API_BASE=http://10.0.2.2:5173
EXPO_PUBLIC_REFERRAL_API_BASE=

# Optional explicit web origin for discover route links in mobile Explore tab
# If empty, app falls back to EXPO_PUBLIC_REFERRAL_API_BASE or analytics/daily-derived base
# EXPO_PUBLIC_WEB_APP_URL=https://your-web-app-origin
EXPO_PUBLIC_WEB_APP_URL=

# Push toggle (0 = skip push registration/test flow, 1 = enable)
EXPO_PUBLIC_PUSH_ENABLED=0

# Optional explicit API base for push test endpoint (/api/push/test)
# If empty, app falls back to EXPO_PUBLIC_REFERRAL_API_BASE then analytics/daily-derived base
# Android emulator local dev example:
# EXPO_PUBLIC_PUSH_API_BASE=http://10.0.2.2:5173
EXPO_PUBLIC_PUSH_API_BASE=

# Recommended EAS project id for Expo push token registration (SDK 53+ dev client flow)
# If empty, app tries to resolve from app config constants
EXPO_PUBLIC_EXPO_PROJECT_ID=

# Local-only internal QA/debug surfaces. Keep 0 for release-style runs.
EXPO_PUBLIC_MOBILE_INTERNAL_SURFACES=0
