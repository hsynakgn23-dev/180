# Copy this file to apps/mobile/android/keystore.properties before generating a
# signed Android App Bundle in Android Studio or via Gradle.
#
# Use the same upload keystore already associated with Play App Signing / EAS.
# The storeFile path is relative to apps/mobile/android.
storeFile=app/upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME